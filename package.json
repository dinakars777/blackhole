{
  "name": "@dinakars777/blackhole",
  "version": "1.0.0",
  "description": "🕳️ A visually satisfying CLI tool to scan and destroy heavy, unused node_modules folders.",
  "main": "dist/index.js",
  "bin": {
    "blackhole": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --clean",
    "dev": "ts-node src/index.ts",
    "test": "node --test --require ts-node/register test/core.test.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "cli",
    "clean",
    "node_modules",
    "space",
    "reclaim",
    "delete",
    "fast-glob",
    "interactive"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
